{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Agent|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts describe",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "^Skill$",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts skill",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts start",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts stop",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^TaskCreate$",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts task-create",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "^TaskUpdate$",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts task-update",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "^TodoWrite$",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts todo",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/subagent-hook.ts turnend",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  }
}
