# Test-harness env for the clod-tmux container. Copy to docker.env (gitignored via *.env) and fill in.
# Use a SEPARATE test bot (not the production @clode_code007_bot) so the two hubs never share a chat.

# BotFather token for the TEST bot
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME

# Telegram user ids allowed to drive the test bot (comma-separated). Put your own id here.
TELEGRAM_ADMINS=1220362133

# Write the full debug timeline (screen snapshots + tg in/out) to
# ~/.claude/channels/telegram/screenlog.jsonl — ON here so the run is fully observable.
TELEGRAM_DEBUG_LOG=1

# Optional: OpenAI key for voice STT/TTS in the test bot (leave blank to disable voice).
OPENAI_API_KEY=
